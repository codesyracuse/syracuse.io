---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHead from "../components/SectionHead.astro";
import Row from "../components/Row.astro";
import Chip from "../components/Chip.astro";
import StatsStrip from "../components/StatsStrip.astro";
import Startcard from "../components/Startcard.astro";
import { getUpcomingEvents, type MeetupEvent } from "../lib/meetup";
import { fetchJobs, generateSlug, type JobKitJob } from "../lib/jobkit";
import { getEventsThisMonth, SLACK_MEMBER_COUNT } from "../lib/stats";
import { SLACK_INVITE_URL, ADD_COMPANY_URL } from "../lib/site";

export const prerender = true;

const TZ = "America/New_York";

function formatWhen(iso: string): string {
  const d = new Date(iso);
  const weekday = d
    .toLocaleDateString("en-US", { weekday: "short", timeZone: TZ })
    .toUpperCase();
  const [month, day] = d
    .toLocaleDateString("en-US", {
      month: "2-digit",
      day: "2-digit",
      timeZone: TZ,
    })
    .split("/");
  return `${weekday} ${month}·${day}`;
}

function formatTime(iso: string): string {
  const d = new Date(iso);
  return d
    .toLocaleTimeString("en-US", {
      hour: "numeric",
      minute: "2-digit",
      timeZone: TZ,
    })
    .replace(":00", "")
    .replace(" ", "")
    .toLowerCase();
}

function eventWhere(event: MeetupEvent): string {
  const venue = event.venue?.name ?? "location TBA";
  return `${venue} · ${formatTime(event.dateTime)}`;
}

const nextEvents = getUpcomingEvents().slice(0, 3);

// Fetched at build time; the section degrades to a pointer at /jobs if the
// API is unreachable so a bad fetch never breaks the deploy.
let recentJobs: JobKitJob[] | null = null;
let openJobCount: number | null = null;
try {
  const jobs = await fetchJobs();
  openJobCount = jobs.length;
  recentJobs = [...jobs]
    .sort(
      (a, b) =>
        new Date(b.created_at).getTime() - new Date(a.created_at).getTime()
    )
    .slice(0, 3);
} catch {
  recentJobs = null;
}

const companies = await getCollection("companies");
const venues = await getCollection("venues");
const venueTypeLabel = { cowork: "COWORK", cafe: "CAFÉ", free: "FREE" } as const;
const featuredVenues = (["cowork", "cafe", "free"] as const)
  .map((type) => venues.find((v) => v.data.type === type))
  .filter((v) => v !== undefined);
const newestCompanies = [...companies]
  .sort((a, b) => b.data.added.getTime() - a.data.added.getTime())
  .slice(0, 5);

const stats = [
  { value: getEventsThisMonth(), label: "events this month" },
  { value: SLACK_MEMBER_COUNT, label: "members on Slack" },
  { value: companies.length, label: "companies listed" },
  { value: openJobCount ?? "—", label: "open roles" },
];
---

<BaseLayout
  content={{
    title: "Syracuse.io — the Syracuse, NY tech community",
    description:
      "Every meetup, every hiring company, every good place to open a laptop in the Salt City — maintained in the open by the people in it.",
  }}
  editPath="src/pages/index.astro"
>
  <Fragment slot="hero">
    <div class="wrap pb-8 pt-7">
      <p class="eyebrow mb-3.5">Salt City · Central New York</p>
      <h1
        class="max-w-[18ch] text-[clamp(28px,6vw,52px)] font-extrabold leading-[1.05]"
      >
        Syracuse builds software. <em class="not-italic text-plow"
          >Come build with us.</em
        >
      </h1>
      <p class="mt-3 max-w-[52ch] text-[15px] text-[#c9cdc8]">
        Every meetup, every hiring company, every good place to open a laptop
        in the Salt City — maintained in the open by the people in it. New
        here? We were all new here once.
      </p>
      <div class="mt-5 flex flex-wrap gap-2.5">
        <a href="/start" class="btn btn-primary">Start here →</a>
        <a href={SLACK_INVITE_URL} class="btn btn-ghost">join the Slack</a>
      </div>
    </div>
  </Fragment>

  <StatsStrip stats={stats} />

  <main class="wrap">
    <section class="pb-1.5 pt-7">
      <SectionHead
        title="NEXT UP"
        href="/groups"
        linkText="all groups + events →"
      />
      {
        nextEvents.map((event) => (
          <Row
            href={event.url}
            when={formatWhen(event.dateTime)}
            what={event.name}
            where={eventWhere(event)}
          />
        ))
      }
    </section>

    <section class="pb-1.5 pt-7">
      <SectionHead
        title="WHO'S HIRING"
        href="/jobs"
        linkText={openJobCount ? `all ${openJobCount} roles →` : "the board →"}
      />
      {
        recentJobs ? (
          recentJobs.map((job) => (
            <Row
              href={`/jobs/${generateSlug(job)}`}
              what={job.title}
              where={`${job.company} · ${job.arrangement}`}
            />
          ))
        ) : (
          <Row href="/jobs" what="See who's hiring on the job board" />
        )
      }
    </section>

    <section class="pb-1.5 pt-7">
      <SectionHead
        title="WHO'S BUILDING"
        href="/companies"
        linkText={`all ${companies.length} companies →`}
      />
      <div class="flex flex-wrap gap-2 pb-2 pt-3.5">
        {
          newestCompanies.map((company) => (
            <Chip
              href={company.data.url}
              name={company.data.name}
              meta={company.data.tagline}
            />
          ))
        }
        <Chip href={ADD_COMPANY_URL} name="+ add your company" add />
      </div>
    </section>

    <section class="pb-1.5 pt-7">
      <SectionHead
        title="WHERE TO WORK"
        href="/work"
        linkText="all spots + day rates →"
      />
      {
        featuredVenues.map((venue) => (
          <Row
            href="/work"
            when={venueTypeLabel[venue.data.type]}
            what={venue.data.name}
            where={venue.data.neighborhood}
          />
        ))
      }
    </section>

    <Startcard />
  </main>
</BaseLayout>
