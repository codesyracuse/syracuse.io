---
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  fetchJobById,
  parseIdFromSlug,
  formatSalary,
  formatRelativeDate,
} from "../../lib/jobkit";

const { slug } = Astro.params;

if (!slug) return Astro.redirect("/jobs");

const jobId = parseIdFromSlug(slug);
if (!jobId) return Astro.redirect("/jobs");

const job = await fetchJobById(jobId);
if (!job) return new Response(null, { status: 404, statusText: "Job not found" });

const salary = formatSalary(job);
const relativeDate = formatRelativeDate(job.created_at);
const descriptionHtml = marked(job.description);

const arrangementLabel =
  job.arrangement === "onsite"
    ? "On-site"
    : job.arrangement.charAt(0).toUpperCase() + job.arrangement.slice(1);

const applyHref =
  job.application_type === "email" && job.application_email
    ? `mailto:${job.application_email}?subject=Application: ${job.title}`
    : job.url;

const pageTitle = `${job.title} at ${job.company} — Syracuse.io`;
const metaDescription = job.description
  .replace(/[#*[\]]/g, "")
  .slice(0, 160)
  .trim();
---

<BaseLayout content={{ title: pageTitle }}>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={`https://syracuse.io/jobs/${slug}`} />
  </Fragment>

  <div class="mx-auto max-w-3xl px-4 py-12">
    <div class="mb-8">
      <a
        href="/jobs"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-orange-600 hover:text-orange-700 dark:text-orange-400 dark:hover:text-orange-300"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        All jobs
      </a>
    </div>

    <header class="mb-8 flex items-start gap-5">
      {
        job.logo && (
          <img
            src={job.logo}
            alt={`${job.company} logo`}
            class="h-14 w-14 flex-shrink-0 rounded-lg object-contain"
          />
        )
      }

      <div>
        <h1 class="mb-2 text-3xl font-bold text-neutral-900 dark:text-white">
          {job.title}
        </h1>

        <div
          class="mb-3 flex flex-wrap items-center gap-x-2 gap-y-1 text-base text-neutral-600 dark:text-neutral-400"
        >
          {
            job.company_website ? (
              <a
                href={job.company_website}
                target="_blank"
                rel="noopener noreferrer"
                class="font-semibold text-neutral-900 hover:text-orange-600 dark:text-white dark:hover:text-orange-400"
              >
                {job.company}
              </a>
            ) : (
              <span class="font-semibold text-neutral-900 dark:text-white">
                {job.company}
              </span>
            )
          }
          <span>·</span>
          <span>{job.location}</span>
          {
            salary && (
              <>
                <span>·</span>
                <span class="font-medium text-neutral-700 dark:text-neutral-300">
                  {salary}
                </span>
              </>
            )
          }
        </div>

        <div class="flex flex-wrap gap-2">
          <span
            class="rounded-full bg-neutral-100 px-3 py-1 text-sm font-medium text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300"
          >
            {arrangementLabel}
          </span>
          <span
            class="rounded-full bg-neutral-100 px-3 py-1 text-sm font-medium text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300"
          >
            {job.term.name}
          </span>
          <span
            class="rounded-full bg-neutral-100 px-3 py-1 text-sm font-medium text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300"
          >
            {job.category.name}
          </span>
        </div>
      </div>
    </header>

    <div
      class="prose prose-neutral max-w-none dark:prose-invert prose-a:text-orange-600 dark:prose-a:text-orange-400"
    >
      <Fragment set:html={descriptionHtml} />
    </div>

    <div
      class="mt-10 flex flex-wrap items-center gap-4 border-t border-neutral-200 pt-8 dark:border-neutral-800"
    >
      <a
        href={applyHref}
        target={job.application_type === "link" ? "_blank" : undefined}
        rel={job.application_type === "link" ? "noopener noreferrer" : undefined}
        class="inline-block rounded-lg bg-orange-600 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-orange-700"
      >
        Apply for this role
      </a>
      <span class="text-sm text-neutral-400 dark:text-neutral-500">
        Posted {relativeDate}
      </span>
    </div>
  </div>
</BaseLayout>
