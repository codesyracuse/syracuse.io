---
import Page from "../../layouts/Page.astro";
import JobCard from "../../components/jobs/JobCard.astro";
import { fetchJobs, sortJobs } from "../../lib/jobkit";

const SUBJECT = "Post a Job on Syracuse.io";

let jobs = [];
let error = null;

try {
  const allJobs = await fetchJobs();
  jobs = sortJobs(allJobs);
} catch (e) {
  error = e;
  console.error("Failed to fetch jobs:", e);
}
---

<Page
  content={{
    title: "Tech Jobs in Syracuse, NY",
    subtitle:
      "Software development, engineering, and tech jobs in Syracuse and Central New York",
  }}
>
  <div class="not-prose">
    {
      error ? (
        <div class="rounded-lg border-2 border-red-200 bg-red-50 p-6 text-center dark:border-red-900 dark:bg-red-950/20">
          <p class="text-lg text-red-800 dark:text-red-300">
            Unable to load jobs right now. Please try again later.
          </p>
        </div>
      ) : jobs.length === 0 ? (
        <div class="rounded-lg border-2 border-dashed border-neutral-200 py-16 text-center dark:border-neutral-800">
          <p class="mb-2 text-lg font-semibold text-neutral-700 dark:text-neutral-300">
            No jobs posted yet.
          </p>
          <p class="text-neutral-500 dark:text-neutral-400">
            Know of a tech job in Syracuse?{" "}
            <button
              id="post-job-trigger-empty"
              class="font-medium text-orange-600 hover:underline dark:text-orange-400"
            >
              Get it listed.
            </button>
          </p>
        </div>
      ) : (
        <>
          <div class="mb-6 flex items-center justify-between">
            <p class="text-sm text-neutral-500 dark:text-neutral-400">
              {jobs.length} {jobs.length === 1 ? "opening" : "openings"}
            </p>
            <button
              id="post-job-trigger"
              class="rounded-lg bg-orange-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-orange-700"
            >
              + Post a Job
            </button>
          </div>

          <div>
            {jobs.map((job) => (
              <JobCard job={job} />
            ))}
          </div>
        </>
      )
    }
  </div>

  <div class="mx-auto mt-12 max-w-2xl">
    <p>
      Listings curated by the{" "}
      <a href="https://syracuse.io/codes">Code Syracuse</a> community — tech
      jobs in the Central New York area.
    </p>
    <p>
      <button
        id="post-job-trigger-footer"
        class="rounded-lg bg-orange-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-orange-700"
        >+ Post a Job</button
      >
    </p>
  </div>
</Page>

<!-- Post a Job modal -->
<dialog
  id="post-job-modal"
  class="w-full max-w-md rounded-2xl bg-white p-8 shadow-2xl backdrop:bg-black/50 dark:bg-neutral-900"
>
  <div class="mb-6 flex items-start justify-between">
    <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">
      Post a Job
    </h2>
    <button
      id="post-job-close"
      aria-label="Close"
      class="rounded-full border-2 border-neutral-300 p-1.5 text-neutral-500 transition-colors hover:border-neutral-400 hover:text-neutral-700 dark:border-neutral-600 dark:text-neutral-400 dark:hover:border-neutral-500 dark:hover:text-neutral-200"
    >
      <svg
        class="h-4 w-4"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <p class="mb-3 text-neutral-600 dark:text-neutral-400">
    Send us an email at:
  </p>

  <div
    class="mb-4 flex items-center gap-3 rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 dark:border-neutral-700 dark:bg-neutral-800"
  >
    <span
      id="modal-email"
      class="flex-1 font-mono text-sm text-neutral-800 dark:text-neutral-200"
    ></span>
    <button
      id="copy-email-btn"
      class="flex items-center gap-1.5 rounded-lg bg-orange-600 px-3 py-1.5 text-sm font-semibold text-white transition-colors hover:bg-orange-700"
    >
      <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20">
        <path
          d="M8 2a1 1 0 000 2h2a1 1 0 100-2H8z M3 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v6h-4.586l1.293-1.293a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L10.414 13H15v3a2 2 0 01-2 2H5a2 2 0 01-2-2V5z"
        ></path>
      </svg>
      <span id="copy-label">Copy</span>
    </button>
  </div>

  <p class="mb-6 text-sm text-neutral-500 dark:text-neutral-400">
    Subject: <span class="font-mono text-neutral-700 dark:text-neutral-300"
      >{SUBJECT}</span
    >
  </p>

  <a
    id="open-email-link"
    href="#"
    class="flex w-full items-center justify-center gap-2 rounded-lg bg-neutral-900 py-3 text-base font-semibold text-white transition-colors hover:bg-neutral-700 dark:bg-white dark:text-neutral-900 dark:hover:bg-neutral-100"
  >
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
      ></path>
    </svg>
    Open in email app
  </a>
</dialog>

<script define:vars={{ SUBJECT }}>
  const e = ["mike", "syracuse.io"].join("@");

  document.getElementById("modal-email").textContent = e;
  document.getElementById("open-email-link").href =
    `mailto:${e}?subject=${encodeURIComponent(SUBJECT)}`;

  const modal = document.getElementById("post-job-modal");
  ["post-job-trigger", "post-job-trigger-empty", "post-job-trigger-footer"].forEach(
    (id) => document.getElementById(id)?.addEventListener("click", () => modal.showModal())
  );

  document.getElementById("post-job-close").addEventListener("click", () => modal.close());
  modal.addEventListener("click", (ev) => { if (ev.target === modal) modal.close(); });

  const copyLabel = document.getElementById("copy-label");
  document.getElementById("copy-email-btn").addEventListener("click", async () => {
    await navigator.clipboard.writeText(e);
    copyLabel.textContent = "Copied!";
    setTimeout(() => (copyLabel.textContent = "Copy"), 2000);
  });
</script>
