---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHead from "../../components/SectionHead.astro";
import JobCard from "../../components/jobs/JobCard.astro";
import { getOpenJobs } from "../../lib/jobs";

const SUBJECT = "Post a Job on Syracuse.io";

const jobs = await getOpenJobs();

const activeWork = Astro.url.searchParams.get("work");
const activeCategory = Astro.url.searchParams.get("category");

function countBy<T>(items: T[], key: (item: T) => string): [string, number][] {
  const counts = new Map<string, number>();
  for (const item of items) {
    const k = key(item);
    counts.set(k, (counts.get(k) ?? 0) + 1);
  }
  return [...counts.entries()].sort((a, b) => b[1] - a[1]);
}

const workFilters = countBy(jobs, (j) => j.data.arrangement);
const categoryFilters = countBy(jobs, (j) => j.data.category);

const filtered = jobs.filter(
  (j) =>
    (!activeWork || j.data.arrangement === activeWork) &&
    (!activeCategory || j.data.category === activeCategory)
);

const companyCount = new Set(jobs.map((j) => j.data.company)).size;

function filterHref(work: string | null, category: string | null): string {
  const params = new URLSearchParams();
  if (work) params.set("work", work);
  if (category) params.set("category", category);
  const qs = params.toString();
  return qs ? `/jobs?${qs}` : "/jobs";
}

// Filters are query params (no client JS); SSR also keeps the expiry cutoff
// honest between deploys. Cache so Cloudflare doesn't hit origin per request.
Astro.response.headers.set("Cache-Control", "public, max-age=3600");
---

<BaseLayout
  content={{
    title: "Tech jobs in Syracuse, NY — Syracuse.io",
    description:
      "Software development, engineering, and tech jobs in Syracuse and Central New York, curated by the community.",
  }}
  editPath="src/content/jobs"
>
  <div class="wrap">
    <div class="flex flex-wrap items-end justify-between gap-4 pb-6 pt-10">
      <div>
        <h1
          class="text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl"
        >
          Who's hiring
        </h1>
        <p class="mt-3 max-w-[52ch] text-[15px]">
          Tech jobs in Syracuse and Central New York, curated by the community.
          Listings link to the company's own posting — no middlemen, and expired
          roles drop off automatically.
        </p>
        <p class="mt-3 font-mono text-xs opacity-70">
          {
            `${jobs.length} ${jobs.length === 1 ? "open role" : "open roles"} · ${companyCount} ${companyCount === 1 ? "company" : "companies"} hiring`
          }
        </p>
      </div>
      <button id="post-job-trigger" class="btn btn-primary">+ Post a job</button
      >
    </div>

    {
      jobs.length > 0 && (
        <div class="flex flex-wrap items-baseline gap-2 pb-4 font-mono text-xs">
          <span class="opacity-60">work:</span>
          {workFilters.map(([work, count]) => (
            <a
              href={filterHref(
                activeWork === work ? null : work,
                activeCategory
              )}
              class:list={[
                "rounded-[3px] border border-ink px-2 py-1",
                activeWork === work ? "bg-ink text-salt" : "hover:bg-mist",
              ]}
            >
              {work}
              <span class="opacity-60">{count}</span>
            </a>
          ))}
          {categoryFilters.length > 1 && (
            <>
              <span class="pl-2 opacity-60">category:</span>
              {categoryFilters.map(([category, count]) => (
                <a
                  href={filterHref(
                    activeWork,
                    activeCategory === category ? null : category
                  )}
                  class:list={[
                    "rounded-[3px] border border-ink px-2 py-1",
                    activeCategory === category
                      ? "bg-ink text-salt"
                      : "hover:bg-mist",
                  ]}
                >
                  {category}
                  <span class="opacity-60">{count}</span>
                </a>
              ))}
            </>
          )}
          {(activeWork || activeCategory) && (
            <a href="/jobs" class="px-2 py-1 text-brick hover:underline">
              × clear filters
            </a>
          )}
        </div>
      )
    }

    <SectionHead
      title={`${filtered.length} ${filtered.length === 1 ? "ROLE" : "ROLES"}`}
    />

    <div class="space-y-3 pb-2 pt-4">
      {
        filtered.length === 0 ? (
          <p class="py-8 text-center text-[15px]">
            {jobs.length === 0
              ? "No open roles right now. Hiring? "
              : "Nothing matches those filters. Hiring? "}
            <button
              id="post-job-trigger-empty"
              class="font-semibold text-brick hover:underline"
            >
              Get your job listed.
            </button>
          </p>
        ) : (
          filtered.map((job) => <JobCard job={job} />)
        )
      }
    </div>

    <p class="pb-4 pt-6 font-mono text-xs opacity-60">
      Listings curated by <a href="/codes" class="text-brick hover:underline"
        >CODES</a
      > — posting is free for community companies; featured slots keep the meetups
      fed.
    </p>
  </div>
</BaseLayout>

<!-- Post a Job modal -->
<dialog
  id="post-job-modal"
  class="backdrop:bg-ink/60 w-full max-w-md rounded border-2 border-ink bg-card p-7"
>
  <div class="mb-5 flex items-start justify-between">
    <h2 class="sign text-xl">Post a job</h2>
    <button
      id="post-job-close"
      aria-label="Close"
      class="rounded-[3px] border-2 border-ink px-2 py-0.5 font-mono text-xs hover:bg-ink hover:text-salt"
    >
      esc
    </button>
  </div>

  <p class="mb-3 text-sm">
    Email us a link to the posting — we'll take it from there:
  </p>

  <div
    class="mb-4 flex items-center gap-3 rounded-[3px] border border-line bg-salt px-3.5 py-2.5"
  >
    <span id="modal-email" class="flex-1 font-mono text-sm"></span>
    <button
      id="copy-email-btn"
      class="rounded-[3px] bg-ink px-2.5 py-1 font-mono text-xs font-bold text-salt hover:bg-brick"
    >
      <span id="copy-label">copy</span>
    </button>
  </div>

  <p class="mb-5 font-mono text-xs opacity-70">
    subject: {SUBJECT}
  </p>

  <a
    id="open-email-link"
    href="mailto:"
    class="btn btn-primary block w-full text-center">Open in email app →</a
  >
</dialog>

<script define:vars={{ SUBJECT }}>
  const e = ["mike", "syracuse.io"].join("@");

  document.getElementById("modal-email").textContent = e;
  document.getElementById("open-email-link").href =
    `mailto:${e}?subject=${encodeURIComponent(SUBJECT)}`;

  const modal = document.getElementById("post-job-modal");
  ["post-job-trigger", "post-job-trigger-empty"].forEach((id) =>
    document
      .getElementById(id)
      ?.addEventListener("click", () => modal.showModal())
  );

  document
    .getElementById("post-job-close")
    .addEventListener("click", () => modal.close());
  modal.addEventListener("click", (ev) => {
    if (ev.target === modal) modal.close();
  });

  const copyLabel = document.getElementById("copy-label");
  document
    .getElementById("copy-email-btn")
    .addEventListener("click", async () => {
      await navigator.clipboard.writeText(e);
      copyLabel.textContent = "copied!";
      setTimeout(() => (copyLabel.textContent = "copy"), 2000);
    });

  // Copy-link anchors: without JS they navigate to /jobs#slug (URL bar has
  // the link); with JS they copy it and flash confirmation.
  document.querySelectorAll(".copy-link").forEach((link) => {
    link.addEventListener("click", async (ev) => {
      ev.preventDefault();
      const url = `${location.origin}/jobs#${link.dataset.slug}`;
      history.replaceState(null, "", `#${link.dataset.slug}`);
      await navigator.clipboard.writeText(url);
      const original = link.textContent;
      link.textContent = "copied!";
      setTimeout(() => (link.textContent = original), 2000);
    });
  });

  // Arriving on /jobs#slug: expand that card's details.
  if (location.hash) {
    const card = document.getElementById(location.hash.slice(1));
    card?.querySelector("details")?.setAttribute("open", "");
  }
</script>
