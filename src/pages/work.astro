---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHead from "../components/SectionHead.astro";
import VenueCard from "../components/VenueCard.astro";
import { ADD_VENUE_URL } from "../lib/site";

export const prerender = true;

const venues = await getCollection("venues");
const byType = (type: "cowork" | "cafe" | "free") =>
  venues
    .filter((v) => v.data.type === type)
    .sort((a, b) => a.data.name.localeCompare(b.data.name));

const sections = [
  {
    title: "COWORK",
    venues: byType("cowork"),
    note: "Day passes, dedicated desks, and conference rooms. Rates change — always check the venue's own pricing page.",
  },
  {
    title: "CAFÉS",
    venues: byType("cafe"),
    note: "Etiquette: buy a drink an hour. These are businesses, not offices.",
  },
  {
    title: "FREE",
    venues: byType("free"),
    note: "Genuinely free. Book a room, bring headphones, thank a librarian.",
  },
];
---

<BaseLayout
  content={{
    title: "Where to work — Syracuse.io",
    description:
      "Coworking spaces, laptop-friendly cafés, and free bookable rooms in Syracuse, NY.",
  }}
  editPath="src/content/venues"
>
  <div class="wrap">
    <div class="pb-4 pt-10">
      <h1
        class="text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl"
      >
        Where to work
      </h1>
      <p class="mt-3 max-w-[52ch] text-[15px]">
        Good places to open a laptop in the Salt City — coworking spaces,
        cafés that don't mind you camping, and rooms that cost nothing.
      </p>
    </div>

    {
      sections.map((section) => (
        <section class="pb-2 pt-6">
          <SectionHead title={section.title} />
          <p class="pt-3 font-mono text-xs opacity-70">{section.note}</p>
          <div class="grid gap-3 pb-2 pt-4 sm:grid-cols-2 md:grid-cols-3">
            {section.venues.map((venue) => (
              <VenueCard venue={venue} />
            ))}
          </div>
        </section>
      ))
    }

    <p class="pb-4 pt-6 font-mono text-xs opacity-60">
      Know a spot that belongs here?
      <a href={ADD_VENUE_URL} class="text-brick hover:underline"
        >suggest a venue →</a
      > — it's one markdown file, and the easiest first contribution there is.
    </p>
  </div>
</BaseLayout>
