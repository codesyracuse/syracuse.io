---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHead from "../components/SectionHead.astro";
import Row from "../components/Row.astro";
import {
  getUpcomingEvents,
  getPastEvents,
  type MeetupEvent,
} from "../lib/meetup";
import { formatWhen, formatMonth, eventWhere } from "../lib/format";
import { GITHUB_REPO_URL } from "../lib/site";

export const prerender = true;

function groupByMonth(events: MeetupEvent[]): [string, MeetupEvent[]][] {
  const months = new Map<string, MeetupEvent[]>();
  for (const event of events) {
    const key = formatMonth(event.dateTime);
    if (!months.has(key)) months.set(key, []);
    months.get(key)!.push(event);
  }
  return [...months.entries()];
}

const upcomingByMonth = groupByMonth(getUpcomingEvents());

// Past events collapse; cap at 12 months so the page doesn't scroll forever.
const PAST_MONTH_LIMIT = 12;
const pastByMonth = groupByMonth(getPastEvents()).slice(0, PAST_MONTH_LIMIT);

const submitUrl = `${GITHUB_REPO_URL}/issues/new?title=${encodeURIComponent("Submit an event")}`;
---

<BaseLayout
  content={{
    title: "Events — Syracuse.io",
    description:
      "Every tech meetup and event in Syracuse and Central New York, in one calendar.",
  }}
  editPath="src/data/events.json"
>
  <div class="wrap">
    <div class="pb-4 pt-10">
      <h1
        class="text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl"
      >
        Events
      </h1>
      <p class="mt-3 max-w-[52ch] text-[15px]">
        Every meetup in one calendar. Free unless noted, no registration
        theater, and nobody checks credentials at the door.
      </p>
    </div>

    {
      upcomingByMonth.length > 0 ? (
        upcomingByMonth.map(([month, events]) => (
          <section class="pb-2 pt-6">
            <SectionHead title={month} />
            {events.map((event) => (
              <Row
                href={event.url}
                when={formatWhen(event.dateTime)}
                what={event.name}
                tag="meetup ↗"
                where={eventWhere(event)}
              />
            ))}
          </section>
        ))
      ) : (
        <section class="pb-2 pt-6">
          <SectionHead title="COMING UP" />
          <Row
            href={submitUrl}
            what="Nothing on the calendar yet — got an event? Submit it"
          />
        </section>
      )
    }

    <section class="pb-2 pt-8">
      <SectionHead title="PAST EVENTS" />
      {
        pastByMonth.map(([month, events]) => (
          <details class="border-b border-line">
            <summary class="cursor-pointer px-0.5 py-3 font-mono text-xs hover:bg-mist">
              {month}
              <span class="opacity-60">
                · {events.length} event{events.length === 1 ? "" : "s"}
              </span>
            </summary>
            {events.map((event) => (
              <Row
                href={event.url}
                when={formatWhen(event.dateTime)}
                what={event.name}
                tag="meetup ↗"
                where={eventWhere(event)}
              />
            ))}
          </details>
        ))
      }
    </section>

    <p class="pb-4 pt-6 font-mono text-xs opacity-60">
      Hosting something?
      <a href={submitUrl} class="text-brick hover:underline"
        >submit an event →</a
      > — a maintainer will get it on the calendar.
    </p>
  </div>
</BaseLayout>
