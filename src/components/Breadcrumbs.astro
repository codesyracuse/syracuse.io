---
interface BreadcrumbItem {
  title: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="font-mono text-xs" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-x-2">
    <li>
      <a href="/" class="text-brick hover:underline">~</a>
    </li>
    {
      items.map((item) => (
        <li class="flex items-center gap-x-2">
          <span class="opacity-40">/</span>
          {item.href ? (
            <a href={item.href} class="text-brick hover:underline">
              {item.title}
            </a>
          ) : (
            <span class="opacity-70" aria-current="page">
              {item.title}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
