---
import { GITHUB_REPO_URL, BUTTONDOWN_SUBSCRIBE_URL } from "../lib/site";

interface Props {
  editPath?: string;
}

const { editPath } = Astro.props;
const editUrl = editPath
  ? `${GITHUB_REPO_URL}/edit/main/${editPath}`
  : GITHUB_REPO_URL;
---

<footer class="mt-8 border-t-[3px] border-ink py-6">
  <div class="wrap">
    <div class="flex flex-wrap justify-between gap-5 text-[13px]">
      <div>
        <p class="eyebrow">One email a month · events, jobs, and who's new</p>
        <form
          action={BUTTONDOWN_SUBSCRIBE_URL}
          method="post"
          class="mt-2 flex gap-2"
        >
          <input
            type="email"
            name="email"
            required
            placeholder="you@example.com"
            aria-label="Email address"
            class="w-[200px] rounded-[3px] border-2 border-ink bg-transparent px-2.5 py-2 font-mono text-xs text-ink"
          />
          <button
            type="submit"
            class="rounded-[3px] border-none bg-ink px-3 py-2 font-mono text-xs font-bold text-salt hover:bg-brick"
          >
            Subscribe
          </button>
        </form>
      </div>
      <div class="text-right font-mono text-xs leading-loose">
        <a href={GITHUB_REPO_URL} class="hover:text-brick"
          >github.com/codesyracuse</a
        ><br />
        <a href={editUrl} class="hover:text-brick">edit this page</a>
        · <a href="/codes" class="hover:text-brick">sponsor a meetup</a>
      </div>
    </div>
    <p class="mt-4 font-mono text-[11px] opacity-60">
      syracuse.io is maintained in the open by
      <a href="/codes" class="underline hover:text-brick">CODES</a>, a 501(c)(3)
      nonprofit. Sponsorship buys the pizza — nothing more, nothing less.
    </p>
  </div>
</footer>
