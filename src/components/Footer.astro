---
import { GITHUB_REPO_URL, CONTACT_EMAIL } from "../lib/site";

interface Props {
  editPath?: string;
}

const { editPath } = Astro.props;
const editUrl = editPath
  ? `${GITHUB_REPO_URL}/edit/main/${editPath}`
  : GITHUB_REPO_URL;
---

<footer class="mt-8 border-t-[3px] border-ink py-6">
  <div class="wrap">
    <div class="flex flex-wrap justify-between gap-5 text-[13px]">
      <div>
        <p class="eyebrow">One email a month · events, jobs, and who's new</p>
        {/* Placeholder until the newsletter provider is wired up (phase 7). */}
        <p class="mt-2 font-mono text-xs">
          get on the list → <a
            href={`mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent("Add me to the syracuse.io newsletter")}`}
            class="text-brick hover:underline">{CONTACT_EMAIL}</a
          >
        </p>
      </div>
      <div class="text-right font-mono text-xs leading-loose">
        <a href={GITHUB_REPO_URL} class="hover:text-brick"
          >github.com/codesyracuse</a
        ><br />
        <a href={editUrl} class="hover:text-brick">edit this page</a>
        · <a
          href={`mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent("Sponsor a meetup")}`}
          class="hover:text-brick">sponsor a meetup</a
        >
      </div>
    </div>
    <p class="mt-4 font-mono text-[11px] opacity-60">
      syracuse.io is maintained in the open by CODES, a 501(c)(3) nonprofit.
      Sponsorship buys the pizza — nothing more, nothing less.
    </p>
  </div>
</footer>
