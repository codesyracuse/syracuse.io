---
import type { CollectionEntry } from "astro:content";

interface Props {
  venue: CollectionEntry<"venues">;
}

const { venue } = Astro.props;
const { name, type, neighborhood, url, pricingUrl, hours, vibe, meetingRooms, notes } =
  venue.data;

const tagColor = {
  cowork: "bg-steel",
  cafe: "bg-brick",
  free: "bg-[#3e6b45]",
}[type];

const tagLabel = { cowork: "cowork", cafe: "café", free: "free" }[type];
---

<div
  class="flex flex-col gap-2 rounded border-2 border-ink bg-card p-3.5 hover:shadow-[4px_4px_0_var(--steel)]"
>
  <div class="flex items-baseline justify-between gap-2">
    <h3 class="text-[15px] font-extrabold">
      <a href={url} class="hover:text-brick">{name}</a>
    </h3>
    <span
      class:list={[
        "whitespace-nowrap rounded-sm px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-[0.08em] text-salt",
        tagColor,
      ]}
    >
      {tagLabel}
    </span>
  </div>
  <p class="font-mono text-[11px] opacity-70">{neighborhood}</p>
  <p class="text-[13px] leading-snug">{vibe}</p>
  {notes && <p class="text-[11px] italic opacity-60">{notes}</p>}
  <div
    class="mt-auto flex justify-between border-t border-dotted border-line pt-2 font-mono text-[11px]"
  >
    <span>{hours}{meetingRooms && " · rooms"}</span>
    {
      pricingUrl && (
        <a href={pricingUrl} class="text-brick hover:underline">
          rates →
        </a>
      )
    }
  </div>
</div>
