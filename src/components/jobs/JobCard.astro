---
import { render } from "astro:content";
import type { Job } from "../../lib/jobs";
import { formatRelativeDate } from "../../lib/format";

interface Props {
  job: Job;
}

const { job } = Astro.props;
const {
  title,
  company,
  url,
  applyEmail,
  location,
  arrangement,
  term,
  category,
  salary,
  posted,
  featured,
} = job.data;

const { Content } = await render(job);

const applyHref = applyEmail
  ? `mailto:${applyEmail}?subject=${encodeURIComponent(`Applying: ${title}`)}`
  : url;
---

<article
  id={job.id}
  class:list={["job-card card scroll-mt-4 p-4", featured && "border-brick"]}
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <div class="flex flex-wrap items-baseline gap-2">
        <h3 class="text-[17px] font-extrabold leading-snug">{title}</h3>
        {
          featured && (
            <span class="rounded-sm bg-brick px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-salt">
              featured
            </span>
          )
        }
      </div>
      <p class="mt-0.5 text-[15px] font-[650]">{company}</p>
    </div>
    <a href={applyHref} class="btn btn-primary shrink-0 !px-3.5 !py-2 text-xs"
      >Apply →</a
    >
  </div>

  <div
    class="mt-2.5 flex flex-wrap items-baseline gap-1.5 font-mono text-[11px]"
  >
    <span class="rounded-[3px] border border-line bg-salt px-2 py-0.5">
      {location} · {arrangement}
    </span>
    <span class="rounded-[3px] border border-line bg-salt px-2 py-0.5">
      {term}
    </span>
    <span class="rounded-[3px] border border-line bg-salt px-2 py-0.5">
      {category}
    </span>
    {
      salary && (
        <span class="rounded-[3px] bg-[#e4ede2] px-2 py-0.5 font-bold text-[#3e6b45]">
          {salary}
        </span>
      )
    }
  </div>

  <details class="job-details mt-2">
    <summary
      class="inline-flex cursor-pointer list-none items-baseline gap-1 font-mono text-xs text-brick hover:underline [&::-webkit-details-marker]:hidden"
    >
      details <span class="chevron">⌄</span>
    </summary>
    <div class="prose prose-sm mt-3 max-w-[72ch] prose-a:text-brick">
      <Content />
    </div>
    <p class="mt-3 font-mono text-xs">
      <a href={url} class="text-brick hover:underline">view full posting ↗</a>
    </p>
  </details>

  <div
    class="mt-3 flex items-baseline justify-between border-t border-dotted border-line pt-2 font-mono text-[11px] opacity-70"
  >
    <time datetime={posted.toISOString()}>{formatRelativeDate(posted)}</time>
    <a
      href={`/jobs#${job.id}`}
      class="copy-link hover:text-brick"
      data-slug={job.id}
      title="Link to this job"># copy link</a
    >
  </div>
</article>

<style>
  details[open] .chevron {
    display: inline-block;
    transform: rotate(180deg) translateY(-2px);
  }
</style>
