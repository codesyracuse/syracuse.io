---
import type { JobKitJob } from "../../lib/jobkit";
import {
  generateSlug,
  formatRelativeDate,
  formatSalary,
} from "../../lib/jobkit";

interface Props {
  job: JobKitJob;
}

const { job } = Astro.props;
const slug = generateSlug(job);
const salary = formatSalary(job);
const relativeDate = formatRelativeDate(job.created_at);
const isFeatured = job.plan.pin || job.plan.highlight;

const arrangementLabel =
  job.arrangement === "onsite"
    ? "On-site"
    : job.arrangement.charAt(0).toUpperCase() + job.arrangement.slice(1);

const excerpt =
  job.description
    .replace(/^#{1,6}\s+.*/gm, "")
    .replace(/\*\*(.+?)\*\*/gs, "$1")
    .replace(/\*(.+?)\*/gs, "$1")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/`([^`]+)`/g, "$1")
    .replace(/^[-*+]\s+/gm, "")
    .replace(/\n+/g, " ")
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 240)
    .replace(/\s+\S*$/, "") + "…";
---

<article
  class={`group border-b py-7 last:border-b-0 ${isFeatured ? "border-orange-200 dark:border-orange-900/40" : "border-neutral-200 dark:border-neutral-800"}`}
>
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <div class="mb-1 flex flex-wrap items-center gap-2">
        {
          isFeatured && (
            <span class="rounded bg-orange-100 px-2 py-0.5 text-xs font-semibold text-orange-700 dark:bg-orange-950 dark:text-orange-400">
              Featured
            </span>
          )
        }
        <a
          href={`/jobs/${slug}`}
          class="text-xl font-bold text-neutral-900 group-hover:text-orange-600 dark:text-white dark:group-hover:text-orange-400"
        >
          {job.title}
        </a>
      </div>

      <div
        class="mb-3 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-neutral-600 dark:text-neutral-400"
      >
        <span class="font-semibold text-neutral-800 dark:text-neutral-200"
          >{job.company}</span
        >
        <span>·</span>
        <span>{job.location}</span>
        {
          salary && (
            <>
              <span>·</span>
              <span class="font-medium text-neutral-700 dark:text-neutral-300">
                {salary}
              </span>
            </>
          )
        }
      </div>

      <div class="mb-3 flex flex-wrap gap-2">
        <span
          class="rounded-full bg-neutral-100 px-3 py-0.5 text-xs font-medium text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300"
        >
          {arrangementLabel}
        </span>
        <span
          class="rounded-full bg-neutral-100 px-3 py-0.5 text-xs font-medium text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300"
        >
          {job.term.name}
        </span>
        <span
          class="rounded-full bg-neutral-100 px-3 py-0.5 text-xs font-medium text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300"
        >
          {job.category.name}
        </span>
      </div>

      <p class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
        {excerpt}
      </p>
    </div>

    <div class="flex flex-shrink-0 flex-col items-end gap-3">
      {
        job.logo && (
          <img
            src={job.logo}
            alt={`${job.company} logo`}
            class="hidden h-10 w-10 rounded object-contain sm:block"
          />
        )
      }
      <time
        class="hidden text-xs text-neutral-400 sm:block dark:text-neutral-500"
        datetime={job.created_at}
      >
        {relativeDate}
      </time>
    </div>
  </div>
</article>
