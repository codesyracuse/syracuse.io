---
interface Props {
  title: string;
  href?: string;
  linkText?: string;
}

const { title, href, linkText } = Astro.props;
---

<div
  class="flex items-baseline justify-between border-b-[3px] border-ink pb-1.5"
>
  <h2 class="font-mono text-[15px] font-bold">
    <i class="not-italic text-brick">┤</i>
    {title}
    <i class="not-italic text-brick">├</i>
  </h2>
  {
    href && (
      <a href={href} class="font-mono text-xs text-brick hover:underline">
        {linkText}
      </a>
    )
  }
</div>
